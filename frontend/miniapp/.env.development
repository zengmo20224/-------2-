# Development environment — requests go through Vite dev server proxy.
# VITE_API_BASE_URL is empty so all /api/* calls use relative paths,
# which are forwarded to http://localhost:8080 by vite.config.ts proxy.
VITE_API_BASE_URL=

# WeChat real-device preview cannot access 127.0.0.1 on the development PC.
# Keep this pointed at the PC LAN address that the phone can open.
VITE_MP_API_BASE_URL=http://10.100.153.71:8080
VITE_MP_API_BASE_FALLBACK_URLS=http://10.110.37.66:8080,http://192.168.137.1:8080

# Tencent Map key for location picker (https://lbs.qq.com/)
# Register and create a key, then paste it here.
VITE_TENCENT_MAP_KEY=
