# PetCare O2O 环境变量样例
# 关联文档：docs/03-configuration-management-plan.md §7.2、docs/07-deployment-guide.md §3
# 复制本文件为 .env 并填入真实值。.env 已在 .gitignore 中，不会被提交。
# 禁止将真实密钥提交到版本库（CMP §1.4 / AGENTS.md 第 4 条）。

# ========== 镜像版本 ==========
# 用于 docker-compose.yml 指定镜像 tag，与 git tag 基线对应
IMAGE_TAG=1.0.0

# ========== MySQL 数据库 ==========
# docker-compose 内部用 mysql:3306；本地开发用 localhost:3306
DB_URL=jdbc:mysql://mysql:3306/petcare_o2o?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=petcare
DB_PASSWORD=changeme

# MySQL 容器初始化用（仅首次创建数据卷时生效）
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=petcare_o2o

# ========== JWT 认证 ==========
# 生产环境必须设置 ≥ 32 字符的随机字符串
JWT_SECRET=
JWT_ISSUER=petcare-o2o-api
JWT_EXPIRATION_MINUTES=120

# ========== AI Provider（V1 保持禁用）==========
AI_PROVIDER_ENABLED=false
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# ========== 端口映射（docker-compose）==========
# 宿主机访问端口（演示用默认值）
ADMIN_WEB_PORT=8080
H5_PORT=8081
API_PORT=8082
MYSQL_PORT=3307

# ========== Jenkins 邮件通知（可选，加分项）==========
# 见 jenkins/README.md §4
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
TEAM_EMAIL=
